# Event tracking utilities
async def track_user_signed_up(analytics_service: AnalyticsService, user_id: str, properties: Dict[str, Any] = None):
    """Track user sign up event"""
    event = AnalyticsEvent(
        event_type=EventType.USER_SIGNED_UP,
        user_id=user_id,
        properties=properties or {}
    )
    await analytics_service.track_event(event)


async def track_task_completed(analytics_service: AnalyticsService, user_id: str, task_id: str, properties: Dict[str, Any] = None):
    """Track task completed event"""
    event = TaskEvent(
        event_type=EventType.TASK_COMPLETED,
        user_id=user_id,
        task_id=task_id,
        properties=properties or {}
    )
    await analytics_service.track_event(event)


async def track_chat_message_sent(analytics_service: AnalyticsService, user_id: str, message_id: str, properties: Dict[str, Any] = None):
    """Track chat message sent event"""
    event = ChatEvent(
        event_type=EventType.CHAT_MESSAGE_SENT,
        user_id=user_id,
        message_id=message_id,
        properties=properties or {}
    )
    await analytics_service.track_event(event)


async def track_tool_call_result(
    analytics_service: AnalyticsService,
    user_id: str,
    tool_name: str,
    success: bool,
    properties: Dict[str, Any] = None
):
    """Track tool call result"""
    event_type = EventType.TOOL_CALL_SUCCESS if success else EventType.TOOL_CALL_FAILURE
    event = ChatEvent(
        event_type=event_type,
        user_id=user_id,
        tool_name=tool_name,
        tool_success=success,
        properties=properties or {}
    )
    await analytics_service.track_event(event)
