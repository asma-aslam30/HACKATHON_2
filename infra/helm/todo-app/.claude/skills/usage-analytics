# Event models
class EventType(str, Enum):
    USER_SIGNED_UP = "user_signed_up"
    USER_LOGGED_IN = "user_logged_in"
    USER_LOGGED_OUT = "user_logged_out"
    TASK_CREATED = "task_created"
    TASK_COMPLETED = "task_completed"
    TASK_DELETED = "task_deleted"
    TASK_EDITED = "task_edited"
    CHAT_MESSAGE_SENT = "chat_message_sent"
    CHAT_MESSAGE_RECEIVED = "chat_message_received"
    TOOL_CALL_INITIATED = "tool_call_initiated"
    TOOL_CALL_SUCCESS = "tool_call_success"
    TOOL_CALL_FAILURE = "tool_call_failure"
    FEATURE_USED = "feature_used"
    FEATURE_FEEDBACK_SUBMITTED = "feature_feedback_submitted"


class AnalyticsEvent(BaseModel):
    """Base analytics event model"""
    event_type: EventType
    user_id: str
    timestamp: datetime = Field(default_factory=datetime.utcnow)
    properties: Dict[str, Any] = Field(default_factory=dict)
    session_id: Optional[str] = None
    platform: Optional[str] = None
    version: Optional[str] = None


class TaskEvent(AnalyticsEvent):
    """Task-specific event model"""
    task_id: str
    task_priority: Optional[str] = None
    task_category: Optional[str] = None
    time_spent: Optional[float] = None
    completion_method: Optional[str] = None


class ChatEvent(AnalyticsEvent):
    """Chat-specific event model"""
    message_id: Optional[str] = None
    message_length: Optional[int] = None
    tool_name: Optional[str] = None
    tool_success: Optional[bool] = None
    chat_duration: Optional[float] = None


