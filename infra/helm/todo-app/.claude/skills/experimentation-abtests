import numpy as np
from scipy import stats

def z_test_two_proportions(p1, p2, n1, n2):
    """
    Perform a two-proportion z-test
    """
    # Pooled proportion
    p_pooled = (p1 * n1 + p2 * n2) / (n1 + n2)

    # Standard error
    se = np.sqrt(p_pooled * (1 - p_pooled) * (1/n1 + 1/n2))

    # Z-score
    z_score = (p1 - p2) / se

    # P-value (two-tailed)
    p_value = 2 * (1 - stats.norm.cdf(abs(z_score)))

    return z_score, p_value

def t_test_two_means(mean1, std1, n1, mean2, std2, n2):
    """
    Perform a two-sample t-test
    """
    # Pooled standard deviation
    pooled_std = np.sqrt(((n1 - 1) * std1**2 + (n2 - 1) * std2**2) / (n1 + n2 - 2))

    # Standard error
    se = pooled_std * np.sqrt(1/n1 + 1/n2)

    # T-score
    t_score = (mean1 - mean2) / se

    # Degrees of freedom
    df = n1 + n2 - 2

    # P-value (two-tailed)
    p_value = 2 * (1 - stats.t.cdf(abs(t_score), df))

    return t_score, p_value, df

def test_ab_significance():
    """
    Test A/B experiment significance
    """
    # Example: Conversion rate test
    control_conversion = 0.65  # 65% conversion rate
    treatment_conversion = 0.68  # 68% conversion rate
    control_sample = 5000
    treatment_sample = 5000

    z_score, p_value = z_test_two_proportions(
        control_conversion, treatment_conversion,
        control_sample, treatment_sample
    )

    print(f"Z-score: {z_score:.4f}")
    print(f"P-value: {p_value:.4f}")
    print(f"Significant at 0.05 level: {p_value < 0.05}")

    # Example: Continuous metric test
    control_mean = 150.0  # Average session time in seconds
    control_std = 50.0
    treatment_mean = 160.0
    treatment_std = 55.0

    t_score, p_value, df = t_test_two_means(
        control_mean, control_std, control_sample,
        treatment_mean, treatment_std, treatment_sample
    )

    print(f"T-score: {t_score:.4f}")
    print(f"P-value: {p_value:.4f}")
    print(f"Degrees of freedom: {df}")
    print(f"Significant at 0.05 level: {p_value < 0.05}")

if __name__ == "__main__":
    test_ab_significance()
