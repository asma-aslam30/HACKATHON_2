    print(f"\nResults:")
    print(f"  Relative Improvement: {results['relative_improvement']:.2f}%")
    print(f"  Z-score: {results['z_score']:.4f}")
    print(f"  P-value: {results['p_value']:.4f}")
    print(f"  Statistically Significant: {results['significant']}")
    print(f"  Control 95% CI: [{results['control_ci'][0]:.3f}, {results['control_ci'][1]:.3f}]")
    print(f"  Treatment 95% CI: [{results['treatment_ci'][0]:.3f}, {results['treatment_ci'][1]:.3f}]")

    # Create visualization
