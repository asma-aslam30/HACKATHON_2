import pandas as pd
import numpy as np
from scipy import stats
import matplotlib.pyplot as plt
import seaborn as sns

def analyze_ab_test(control_conversions, control_total, treatment_conversions, treatment_total):
    """
    Analyze A/B test results
    """
    # Calculate conversion rates
    control_rate = control_conversions / control_total
    treatment_rate = treatment_conversions / treatment_total

    # Calculate relative improvement
    relative_improvement = (treatment_rate - control_rate) / control_rate * 100

    # Perform statistical significance test (z-test for proportions)
    # Pooled proportion
    pooled_p = (control_conversions + treatment_conversions) / (control_total + treatment_total)

    # Standard error
    se = np.sqrt(pooled_p * (1 - pooled_p) * (1/control_total + 1/treatment_total))

    # Z-score
    z_score = (treatment_rate - control_rate) / se

    # P-value (two-tailed)
    p_value = 2 * (1 - stats.norm.cdf(abs(z_score)))

    # Confidence intervals
    control_se = np.sqrt((control_rate * (1 - control_rate)) / control_total)
    treatment_se = np.sqrt((treatment_rate * (1 - treatment_rate)) / treatment_total)

    control_ci = (control_rate - 1.96 * control_se, control_rate + 1.96 * control_se)
    treatment_ci = (treatment_rate - 1.96 * treatment_se, treatment_rate + 1.96 * treatment_se)

    results = {
        'control_rate': control_rate,
        'treatment_rate': treatment_rate,
        'relative_improvement': relative_improvement,
        'z_score': z_score,
        'p_value': p_value,
        'significant': p_value < 0.05,
        'confidence_level': 0.95,
        'control_ci': control_ci,
        'treatment_ci': treatment_ci,
        'control_total': control_total,
        'treatment_total': treatment_total
    }

    return results

def create_visualization(results):
    """
    Create visualization of A/B test results
    """
    variants = ['Control', 'Treatment']
    rates = [results['control_rate'], results['treatment_rate']]
    ci_lower = [results['control_ci'][0], results['treatment_ci'][0]]
    ci_upper = [results['control_ci'][1], results['treatment_ci'][1]]

    plt.figure(figsize=(10, 6))
    bars = plt.bar(variants, rates, yerr=[np.array(rates) - np.array(ci_lower), np.array(ci_upper) - np.array(rates)],
                   capsize=10, error_kw={'elinewidth': 2, 'capthick': 2})

    plt.ylabel('Conversion Rate')
    plt.title('A/B Test Results: Conversion Rates with 95% Confidence Intervals')
    plt.ylim(0, max(ci_upper) * 1.1)

    # Add value labels on bars
    for i, (bar, rate) in enumerate(zip(bars, rates)):
        plt.text(bar.get_x() + bar.get_width()/2, bar.get_height() + 0.005,
                f'{rate:.3f}', ha='center', va='bottom')

    plt.tight_layout()
    plt.savefig('ab_test_results.png')
    print("Visualization saved as ab_test_results.png")

def main():
