# Create Jaeger configuration
cat > infra/monitoring/jaeger-config.yml << 'JAEGER_EOF'
# Jaeger configuration for distributed tracing
version: '3.8'

services:
  jaeger:
    image: jaegertracing/all-in-one:latest
    container_name: jaeger
    restart: unless-stopped
    environment:
      - COLLECTOR_OTLP_ENABLED=true
      - SPAN_STORAGE_TYPE=memory
    ports:
      - "16686:16686"  # UI
      - "14268:14268"  # Jaeger HTTP Thrift
      - "14250:14250"  # Jaeger gRPC
      - "4317:4317"    # OTLP gRPC
      - "4318:4318"    # OTLP HTTP
      - "5778:5778"    # Config endpoint
      - "6831:6831/udp" # Jaeger compact
      - "6832:6832/udp" # Jaeger binary
    volumes:
      - ./jaeger-storage:/tmp/jaeger
    networks:
      - monitoring

  # Jaeger agent for sidecar deployment
  jaeger-agent:
    image: jaegertracing/jaeger-agent:latest
    container_name: jaeger-agent
    restart: unless-stopped
    command: ["--reporter.grpc.host-port=jaeger:14250"]
    ports:
      - "5775:5775/udp"
      - "6831:6831/udp"
      - "6832:6832/udp"
      - "5778:5778"
    networks:
      - monitoring

networks:
  monitoring:
    driver: bridge
JAEGER_EOF

