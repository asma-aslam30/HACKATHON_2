# Copy this to .env.local and fill in values

# Neon DB — get from neon.tech dashboard
DATABASE_URL=postgresql://neondb_owner:PASSWORD@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://neondb_owner:PASSWORD@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Better Auth — any random 32+ char string
AUTH_SECRET=generate-a-random-secret-here

# App URLs (local dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
