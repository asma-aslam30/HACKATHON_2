# Copy this to .env and fill in your values

# Neon DB — get from neon.tech dashboard
# IMPORTANT: Do NOT include channel_binding=require — psycopg2 doesn't support it
DATABASE_URL=postgresql://neondb_owner:PASSWORD@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://neondb_owner:PASSWORD@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Gemini — get from aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# App
FRONTEND_URL=http://localhost:3000
BETTER_AUTH_SECRET=generate-a-random-secret-here
